# Language Translation Comparison Script
# This script reads English Article N, translates it to all target languages,
# then has a judge model compare each translation against the canonical version.
# 
# Usage: /script lang_compare.chatdsl x=N y=MODEL_TRANSLATOR z=MODEL_JUDGE
#   Where N is 1-10, MODEL_TRANSLATOR is the translator model, MODEL_JUDGE is the judge model
#   If parameters are not provided, defaults are used (x=1, y=llama1, z=mistral_1)

# Configuration - Parameter handling
# Map x, y, z parameters to meaningful variable names
# x = article number (1-10)
# y = translator model
# z = judge model

if ${x} != "" then set article_num = ${x}
if ${article_num} == "" then set article_num = 1

if ${y} != "" then set model_translator = ${y}
if ${model_translator} == "" then set model_translator = "llama1"

if ${z} != "" then set model_judge = ${z}
if ${model_judge} == "" then set model_judge = "mistral_1"

# Handle file naming: article01-09 vs article10
if ${article_num} == "10" then set article_file_num = "10"
if ${article_num} != "10" then set article_file_num = "0${article_num}"

# Set paths
set base_path = "article_${article_num}"
set english_file = "${base_path}/english/article${article_file_num}_english.txt"
set trans_dir = "${base_path}/trans"

# Load the English source text
/file ${english_file}
set english_text = "{file}"

echo "Loaded English Article ${article_num} from ${english_file}"
echo "Translation target: all 9 non-English languages"

# ============================================================
# FRENCH
# ============================================================
set lang = "french"
/model ${model_translator}
/multiline
Translate the following text from English to ${lang}. Be precise and maintain the original meaning:
${english_text}
;;
/multiline
/save ${trans_dir}/article${article_file_num}_${lang}_${model_translator}.txt
/filebank1 ${trans_dir}/article${article_file_num}_${lang}_${model_translator}.txt
 
# Compare with canonical
/model ${model_judge}
/filebank2 ${base_path}/${lang}/article${article_file_num}_${lang}.txt
/multiline
Act as a language and legal expert. Compare the following two ${lang} translations of Article ${article_num}:

ORIGINAL (canonical):
{filebank2}

LLM TRANSLATION:
{filebank1}

Evaluate on these criteria:
1. **Fidelity (0-10)**: Does the LLM translation accurately convey the exact meaning of the original?
2. **Language Comprehension (0-10)**: Is the translation natural, idiomatic, and grammatically correct in ${lang}?
3. **Intent Preservation (0-10)**: Does it preserve the legal-philosophical intent and nuances?
4. **Novel/Incorrect Deviations**: List any additions, omissions, or meanings that diverge from the original.

Provide for each criterion:
- Score
- Justification with specific examples
- Overall assessment of translation quality
- Recommendations for improvement
;;
/multiline
/save ${trans_dir}/article${article_file_num}_${lang}_${model_translator}_comparison.txt

