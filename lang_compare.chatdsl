# FINAL SUMMARY - 
# use variables    
# ============================================================

# load up comparisons
set lang = "japanese"
/filebank4 ${base_path}/${lang}/article${article_file_num}_${lang}.txt
/setvar japanese_compare {filebank4}

set lang = "french"
/filebank4 ${base_path}/${lang}/article${article_file_num}_${lang}.txt
/setvar french_compare {filebank4}

